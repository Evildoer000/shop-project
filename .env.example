APP_ENV=development
DATABASE_URL=postgresql+psycopg://rag:rag@localhost:5432/ecommerce_rag
MILVUS_URI=http://localhost:19530
MILVUS_TOKEN=
MILVUS_COLLECTION=product_chunks
TEXT_MILVUS_COLLECTION=product_chunks
IMAGE_MILVUS_COLLECTION=product_image_chunks
ORGANIZER_DATASET_DIR=./ecommerce_agent_dataset

# OpenAI-compatible chat completion endpoint, e.g. Doubao compatible gateway.
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=deepseek-v4-flash
LLM_TIMEOUT_SECONDS=30
LLM_INPUT_PRICE_PER_1K=
LLM_OUTPUT_PRICE_PER_1K=
LLM_STREAM_INCLUDE_USAGE=true

# OpenAI-compatible embedding endpoint. Keep EMBEDDING_DIM aligned with the model output.
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=
EMBEDDING_DIM=384
EMBEDDING_TIMEOUT_SECONDS=30

# Multimodal image retrieval uses remote DashScope image embeddings by default.
DASHSCOPE_API_KEY=
IMAGE_EMBEDDING_BACKEND=dashscope
IMAGE_EMBEDDING_MODEL=tongyi-embedding-vision-flash-2026-03-06
IMAGE_EMBEDDING_API_KEY=
CLIP_MODEL_NAME=ViT-B-16
CLIP_DEVICE=auto
IMAGE_EMBEDDING_DIM=768
IMAGE_RELEVANCE_THRESHOLD=0.20

# Docker bootstrap skips text vector rebuild when DB/Milvus/index fingerprint are current.
# Set true only when product data, embedding model, or indexing strategy changes.
BOOTSTRAP_FORCE_REINDEX=false
BOOTSTRAP_FORCE_IMAGE_REINDEX=false

# Lightweight VLM image understanding. Keep the API key in local .env only.
VLM_API_KEY=
VLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VLM_MODEL=ep-20260514111645-lmgt2
VLM_TIMEOUT_SECONDS=30
VLM_MAX_RETRIES=1

# Harness short-term evidence cache. Redis failures fall back to in-memory cache.
EVIDENCE_CACHE_BACKEND=redis
REDIS_URL=redis://localhost:6379/0
EVIDENCE_CACHE_KEY_PREFIX=ecommerce-rag:evidence
EVIDENCE_CACHE_REDIS_TIMEOUT_SECONDS=1.0
EVIDENCE_CACHE_TTL_SECONDS=3600
EVIDENCE_CACHE_RECENT_TURNS=20
EVIDENCE_CACHE_MAX_CANDIDATES_PER_TURN=20

# Rerank backend:
# - hybrid: local vector + BM25 + RRF order only; no rerank API cost.
# - remote: explicitly call the configured rerank endpoint.
RERANK_BACKEND=hybrid

# OpenAI/Jina/FlagEmbedding-style rerank endpoint. Used only when RERANK_BACKEND=remote.
RERANK_API_KEY=
RERANK_BASE_URL=
RERANK_MODEL=
RERANK_TIMEOUT_SECONDS=30

ENABLE_TRAJECTORY_LOG=true
TRAJECTORY_LOG_PATH=server/logs/multihop_trajectories.jsonl

LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
